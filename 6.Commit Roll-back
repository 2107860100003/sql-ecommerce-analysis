-- Error Scenario using Transaction (ROLLBACK)
BEGIN TRANSACTION;
-- First insert works
INSERT INTO customers (customer_id, customer_name, email)
VALUES (3, 'Rohit Singh', 'rohit@gmail.com');
-- Duplicate primary key triggers error
INSERT INTO customers (customer_id, customer_name, email)
VALUES (3, 'Priya Singh', 'priya@gmail.com');
-- Rollback all changes due to error
ROLLBACK;