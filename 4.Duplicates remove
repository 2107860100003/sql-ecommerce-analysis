---SQL script to detect and remove duplicate customers while keeping the most recent
--1. Detect Duplicate Customers
SELECT email, COUNT(*) AS duplicate_count
FROM customers
GROUP BY email
HAVING COUNT(*) > 1;

--2. View Duplicate Rows
SELECT *
FROM customers  
WHERE email IN (
    SELECT email
    FROM customers
    GROUP BY email
    HAVING COUNT(*) > 1
);
----3.Assign Row Numbers to Duplicates
SELECT *,
ROW_NUMBER() OVER(
PARTITION BY email
ORDER BY customer_id DESC
) AS rn
FROM customers;
-----4Remove Duplicate Customers (Keep Latest Record)
DELETE FROM customers
WHERE customer_id IN (
    SELECT customer_id
    FROM (
        SELECT customer_id,
        ROW_NUMBER() OVER(
        PARTITION BY email
        ORDER BY customer_id DESC
        ) AS rn
        FROM customers
    ) t
    WHERE rn > 1
);