-- Raw Data Quality Issues
---1️.Null Values
SELECT *
FROM orders
WHERE order_delivered_customer_date IS NULL;
---2️.Duplicate Records
SELECT order_id, COUNT(*)   
FROM orders
GROUP BY order_id   
HAVING COUNT(*) > 1;
---3️.Inconsistent Data Formats
SELECT order_id, order_date
FROM orders
WHERE order_date NOT LIKE '____-__-__';
----5 Orphan Records
SELECT oi.order_id
FROM order_items oi
LEFT JOIN orders o
ON oi.order_id = o.order_id
WHERE o.order_id IS NULL;
----6 Negative or Invalid Values
SELECT *
FROM payments
WHERE payment_value < 0;
-----7 Outliers
SELECT *    
FROM payments
WHERE payment_value > (SELECT AVG(payment_value) + 3 * STDDEV(payment_value) FROM payments);
-----8 Inconsistent Categorical Data
SELECT DISTINCT Category    
FROM products;
SELECT DISTINCT order_status
FROM orders;
-----9 Product Without Category
SELECT *
FROM products
WHERE product_category_name IS NULL;
----10 Misspelled Data
SELECT DISTINCT Category
FROM products
WHERE Category LIKE '%Electrnics%' OR Category LIKE '%Clthng%';